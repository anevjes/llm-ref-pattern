# Azure AI Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=https:/<>.services.ai.azure.com/api/projects/<bla>

# Model deployment name (e.g. gpt-5.1)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.1

# GitHub personal access token (needs repo scope)
GITHUB_TOKEN=

# GitHub repository in owner/repo format
GITHUB_REPO=anevjes/llm-ref-pattern

# GitHub branch to commit to (default: main)
GITHUB_BRANCH=main

# Bicep processing mode: 'full' or 'chunked'
# - full: reads entire file, modifies in one shot (higher token usage, simpler)
# - chunked: splits file into sections, processes only chunks needing changes (lower token usage)
BICEP_PROCESSING_MODE=full
